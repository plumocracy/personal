{
	"name": "nucleus",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_flags": [
		"nodejs_als"
	],
	"compatibility_date": "2026-04-20",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": true,
			"persist": true,
			"head_sampling_rate": 1
		}
	}
}
