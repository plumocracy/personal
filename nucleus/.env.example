# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# Neon branch management for local development
NEON_API_KEY=""
NEON_PROJECT_ID=""
NEON_DB_NAME="neondb"
NEON_DB_ROLE="neondb_owner"
NEON_PARENT_BRANCH="main"
NEON_DEV_BRANCH_NAME="dev-local"
NEON_DEV_DB_ENV_FILE=".env.neon-dev"
NEON_LOCAL_OVERRIDE_ENV_FILE=".env.local"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# GitHub OAuth
